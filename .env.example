# IA Provider - GROQ (gratuito em https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Modelos gratuitos disponíveis no GROQ (escolha um):
# llama-3.1-8b-instant     → rápido, leve, ideal para documentos (RECOMENDADO)
# llama-3.3-70b-versatile  → mais inteligente, respostas melhores (mais lento)
# meta-llama/llama-4-maverick-17b-128e-instruct → multimodal, mais moderno
# deepseek-r1-distill-70b  → ótimo para raciocínio e análise
GROQ_MODEL=llama-3.1-8b-instant

# URL da aplicação (opcional, para produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000
